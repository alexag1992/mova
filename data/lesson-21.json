        {"be": "Перазваніце, калі ласка", "ru": "Перезвоните, пожалуйста", "transcription": "[пэразваніцэ калі ласка]", "audio": "lesson-21/pierazvanice.mp3", "example": {"be": "Ён заняты. Перазваніце пазней.", "ru": "Он занят. Перезвоните позже."}, "note": ""},
